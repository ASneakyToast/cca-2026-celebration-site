---
import DemoEffectLayout from "../../layouts/DemoEffectLayout.astro";
import ParticleField from "../../components/effects/ParticleField.astro";

const chimeraPaths = [
  {
    d: "M140 38.1L99.009 38.1L99.009 254L140 254L140 38.1ZM18.9189 99.06C9.45949 114.618 -5.55296e-06 130.492 -6.32604e-06 139.382C-7.40282e-06 151.765 11.3513 162.56 23.6486 162.56C35 162.56 46.3514 152.4 46.3514 139.7C46.3514 128.588 39.7298 111.442 39.7298 104.457C39.7298 93.6625 43.1982 89.535 72.2072 38.1L99.009 38.1L99.009 4.02679e-06L61.1712 7.01308e-07L61.1712 26.3525C55.8108 35.56 24.2793 90.4875 18.9189 99.06Z",
    viewBox: [140, 254] as [number, number],
  },
  {
    d: "M142.687 149L142.687 108.981L-1.40763e-05 108.981L-1.75609e-05 149L142.687 149ZM184 46.093L142.687 46.093L142.687 108.981L184 108.981L184 46.093ZM104.553 30.2123C94.3834 30.2123 88.3455 30.2123 84.532 27.0362C78.494 20.6839 84.8496 12.4259 72.4558 3.85036C59.7443 -5.36045 39.0881 2.5799 39.0881 21.0015C39.0881 37.5174 52.1173 46.093 72.4558 46.093L142.687 46.093L142.687 7.97935L104.553 7.97934L104.553 30.2123Z",
    viewBox: [184, 149] as [number, number],
  },
  {
    d: "M45.6566 176.15C45.6566 186.325 43.4217 197.136 37.994 203.177C29.6928 211.762 15.9639 203.177 4.46991 218.439C1.59641 222.255 -7.41712e-06 227.66 -7.88987e-06 233.066C-9.41934e-06 250.553 12.7711 262 30.3313 262C37.0362 262 44.0602 260.092 50.4458 255.005C58.747 248.328 63.2169 233.383 62.8976 218.439L61.6205 176.15L61.6205 162.16L166.343 162.16L166.343 85.8495C166.343 75.6748 168.578 64.8641 174.325 59.1408C182.307 50.2379 196.036 58.8228 207.53 43.5607C210.404 39.7452 212 34.3398 212 28.9345C212 19.7136 207.849 9.5389 198.91 4.45152C194.44 1.90783 188.054 2.55198e-05 181.669 2.49618e-05C159.319 2.30088e-05 148.783 18.1238 149.422 43.5607L150.38 85.8495L150.38 124.005L45.6566 124.005L45.6566 176.15Z",
    viewBox: [212, 262] as [number, number],
  },
  {
    d: "M-2.59782e-06 40.2086L-1.67901e-05 202L40.5613 202L40.5613 40.2086L-2.59782e-06 40.2086ZM83.3582 17.8705C166.716 17.8705 152.983 47.5482 182.366 47.5482C198.335 47.5482 206 37.3365 206 23.9337C206 9.89258 192.586 8.09449e-06 173.104 6.39707e-06C160.648 5.31183e-06 104.757 1.91472 83.3582 1.91472L40.5613 1.91472L40.5613 40.2086L78.8868 40.2086L78.8868 17.8705L83.3582 17.8705Z",
    viewBox: [206, 202] as [number, number],
  },
];

const chimeraColors = ['#00BFB3', '#563D82', '#FFC845', '#E57200', '#005776'];
---

<DemoEffectLayout title="Particle Field — Chimera Demo">
  <ParticleField
    mode="svg"
    svgPaths={chimeraPaths}
    colors={chimeraColors}
    count={50}
    sizeRange={[20, 50]}
    opacityRange={[0.15, 0.5]}
  />

  <div class="demo-overlay">
    <a href="/demo/" class="back-link">&larr; Demo Pages</a>
    <h1 class="demo-title">Particle Field — Chimera</h1>
    <p class="demo-technique">Canvas SVG path particles · Chimera Expanded shapes</p>
  </div>

  <button class="sidebar-toggle" id="sidebar-toggle" aria-label="Toggle controls" aria-expanded="false">
    <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5">
      <circle cx="6" cy="4" r="1.5"/><line x1="6" y1="5.5" x2="6" y2="18"/>
      <circle cx="14" cy="10" r="1.5"/><line x1="14" y1="2" x2="14" y2="8.5"/><line x1="14" y1="11.5" x2="14" y2="18"/>
      <circle cx="10" cy="15" r="1.5"/><line x1="10" y1="2" x2="10" y2="13.5"/><line x1="10" y1="16.5" x2="10" y2="18"/>
    </svg>
  </button>

  <aside class="sidebar" id="sidebar">
    <div class="sidebar-header">
      <h2>Controls</h2>
      <button class="sidebar-close" id="sidebar-close" aria-label="Close controls">&times;</button>
    </div>
    <p class="sidebar-description">
      Chimera Expanded letterform shapes rendered as canvas Path2D particles.
      Each shape is scaled to particle size and drawn with fill.
    </p>
    <div class="controls">
      <div class="control-group">
        <label for="particle-count">Particle Count: <output id="particle-count-val">50</output></label>
        <input type="range" id="particle-count" min="5" max="200" value="50" step="5" />
      </div>
      <div class="control-group">
        <label for="size-min">Min Size: <output id="size-min-val">20</output></label>
        <input type="range" id="size-min" min="5" max="60" value="20" step="1" />
      </div>
      <div class="control-group">
        <label for="size-max">Max Size: <output id="size-max-val">50</output></label>
        <input type="range" id="size-max" min="10" max="120" value="50" step="1" />
      </div>
      <div class="control-group">
        <label for="opacity-min">Min Opacity: <output id="opacity-min-val">0.15</output></label>
        <input type="range" id="opacity-min" min="0.05" max="1" value="0.15" step="0.05" />
      </div>
      <div class="control-group">
        <label for="opacity-max">Max Opacity: <output id="opacity-max-val">0.5</output></label>
        <input type="range" id="opacity-max" min="0.1" max="1" value="0.5" step="0.05" />
      </div>
      <div class="control-group">
        <label for="speed-mult">Speed: <output id="speed-mult-val">1×</output></label>
        <input type="range" id="speed-mult" min="0.1" max="3" value="1" step="0.1" />
      </div>
    </div>
  </aside>
</DemoEffectLayout>

<style>
  /* Overlay info */
  .demo-overlay {
    position: fixed;
    top: 5rem;
    left: var(--space-6);
    z-index: 10;
    pointer-events: none;
  }

  .back-link {
    display: inline-block;
    color: var(--color-muted);
    text-decoration: none;
    font-size: var(--text-sm);
    margin-bottom: var(--space-2);
    pointer-events: auto;
    background: hsla(var(--color-bg-rgb, 0 0% 99%), 0.6);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    padding: var(--space-1) var(--space-2);
    border-radius: 0.25rem;
  }

  .demo-title {
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    margin-bottom: var(--space-1);
    text-shadow: 0 1px 4px hsla(0, 0%, 0%, 0.3);
  }

  .demo-technique {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    text-shadow: 0 1px 4px hsla(0, 0%, 0%, 0.3);
  }

  /* Sidebar toggle */
  .sidebar-toggle {
    position: fixed;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    z-index: 20;
    width: 2.5rem;
    height: 2.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: hsla(var(--color-bg-rgb, 0 0% 99%), 0.7);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid var(--color-border);
    border-right: none;
    border-radius: 0.5rem 0 0 0.5rem;
    cursor: pointer;
    color: var(--color-text);
    transition: background 0.2s ease;
  }

  .sidebar-toggle:hover {
    background: hsla(var(--color-bg-rgb, 0 0% 99%), 0.9);
  }

  .sidebar-toggle[aria-expanded="true"] {
    display: none;
  }

  /* Sidebar */
  .sidebar {
    position: fixed;
    top: 0;
    right: 0;
    width: 280px;
    height: 100vh;
    z-index: 30;
    background: hsla(var(--color-bg-rgb, 0 0% 99%), 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-left: 1px solid var(--color-border);
    padding: var(--space-6);
    overflow-y: auto;
    transform: translateX(100%);
    transition: transform 0.3s ease;
  }

  .sidebar.open {
    transform: translateX(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .sidebar {
      transition: none;
    }
  }

  .sidebar-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-4);
  }

  .sidebar-header h2 {
    font-family: var(--font-heading);
    font-size: var(--text-lg);
  }

  .sidebar-close {
    background: none;
    border: none;
    font-size: var(--text-xl);
    cursor: pointer;
    color: var(--color-muted);
    padding: var(--space-1);
    line-height: 1;
  }

  .sidebar-description {
    color: var(--color-muted);
    font-size: var(--text-sm);
    line-height: 1.6;
    margin-bottom: var(--space-4);
    padding-bottom: var(--space-4);
    border-bottom: 1px solid var(--color-border);
  }

  .control-group {
    margin-bottom: var(--space-3);
  }

  .control-group label {
    display: block;
    font-size: var(--text-sm);
    margin-bottom: var(--space-1);
  }

  .control-group output {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-accent);
  }

  .control-group input[type="range"] {
    width: 100%;
    cursor: pointer;
  }
</style>

<script>
  // Sidebar toggle
  const toggle = document.getElementById('sidebar-toggle')!;
  const sidebar = document.getElementById('sidebar')!;
  const closeBtn = document.getElementById('sidebar-close')!;

  toggle.addEventListener('click', () => {
    sidebar.classList.add('open');
    toggle.setAttribute('aria-expanded', 'true');
  });

  closeBtn.addEventListener('click', () => {
    sidebar.classList.remove('open');
    toggle.setAttribute('aria-expanded', 'false');
  });

  // Controls — update data attributes on the canvas and signal the running animation loop
  const canvas = document.querySelector<HTMLCanvasElement>('.particle-field')!;

  function updateField() {
    const countInput = document.getElementById('particle-count') as HTMLInputElement;
    const sizeMinInput = document.getElementById('size-min') as HTMLInputElement;
    const sizeMaxInput = document.getElementById('size-max') as HTMLInputElement;
    const opacityMinInput = document.getElementById('opacity-min') as HTMLInputElement;
    const opacityMaxInput = document.getElementById('opacity-max') as HTMLInputElement;
    const speedMultInput = document.getElementById('speed-mult') as HTMLInputElement;

    canvas.dataset.count = countInput.value;
    canvas.dataset.sizeRange = JSON.stringify([
      parseFloat(sizeMinInput.value),
      parseFloat(sizeMaxInput.value),
    ]);
    canvas.dataset.opacityRange = JSON.stringify([
      parseFloat(opacityMinInput.value),
      parseFloat(opacityMaxInput.value),
    ]);
    canvas.dataset.speedMult = speedMultInput.value;

    canvas.dispatchEvent(new Event('particle-field:update'));
  }

  // Wire up output displays
  const controls = [
    { id: 'particle-count', valId: 'particle-count-val', suffix: '' },
    { id: 'size-min', valId: 'size-min-val', suffix: '' },
    { id: 'size-max', valId: 'size-max-val', suffix: '' },
    { id: 'opacity-min', valId: 'opacity-min-val', suffix: '' },
    { id: 'opacity-max', valId: 'opacity-max-val', suffix: '' },
    { id: 'speed-mult', valId: 'speed-mult-val', suffix: '×' },
  ];

  let debounceTimer: ReturnType<typeof setTimeout>;

  for (const ctrl of controls) {
    const input = document.getElementById(ctrl.id) as HTMLInputElement;
    const output = document.getElementById(ctrl.valId) as HTMLOutputElement;
    input.addEventListener('input', () => {
      output.textContent = input.value + ctrl.suffix;
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(updateField, 300);
    });
  }
</script>
