---
/**
 * PrismaticFlare — Prismatic light-leak overlay
 * Pure CSS, zero JavaScript. Five offset ellipses/circles with varied blur
 * and hard-stop gradients that rotate to create visible prismatic beams
 * rather than a uniform color wash.
 */
---

<div class="prismatic-flare" aria-hidden="true">
  <div class="flare flare--1"></div>
  <div class="flare flare--2"></div>
  <div class="flare flare--3"></div>
  <div class="flare flare--4"></div>
  <div class="flare flare--5"></div>
</div>

<style>
  .prismatic-flare {
    position: fixed;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    opacity: var(--flare-opacity, 0.045);
    mix-blend-mode: normal;
    overflow: hidden;
  }

  .flare {
    position: absolute;
    border-radius: 50%;
    will-change: transform;
  }

  /* 1 — Wide teal ellipse, top-left corner, overhanging */
  .flare--1 {
    width: 90vw;
    height: 50vh;
    top: -15vh;
    left: -20vw;
    filter: blur(40px);
    background: linear-gradient(
      135deg,
      var(--color-teal),
      var(--color-teal) 35%,
      transparent 60%
    );
    opacity: 0.7;
  }

  /* 2 — Tall pink ellipse, right edge */
  .flare--2 {
    width: 40vw;
    height: 80vh;
    top: 10vh;
    right: -10vw;
    left: auto;
    filter: blur(30px);
    background: linear-gradient(
      200deg,
      var(--color-pink),
      var(--color-pink) 30%,
      transparent 50%
    );
    opacity: 0.6;
  }

  /* 3 — Warm yellow circle, bottom-left */
  .flare--3 {
    width: 50vmax;
    height: 50vmax;
    bottom: -15vmax;
    left: -10vmax;
    top: auto;
    filter: blur(50px);
    background: radial-gradient(
      circle at center,
      var(--color-yellow) 0%,
      var(--color-yellow) 25%,
      transparent 70%
    );
    opacity: 0.65;
  }

  /* 4 — Beam-like conic ellipse, top-right corner */
  .flare--4 {
    width: 70vw;
    height: 35vh;
    top: -10vh;
    right: -15vw;
    left: auto;
    filter: blur(20px);
    background: conic-gradient(
      from 45deg,
      var(--color-yellow),
      transparent 15%,
      transparent 30%,
      var(--color-teal),
      transparent 55%,
      transparent 70%,
      var(--color-yellow),
      transparent 90%
    );
    opacity: 0.8;
  }

  /* 5 — Small teal blend, center-right */
  .flare--5 {
    width: 30vmax;
    height: 30vmax;
    top: 35vh;
    right: 5vw;
    left: auto;
    filter: blur(60px);
    background: radial-gradient(
      circle at center,
      var(--color-teal) 0%,
      var(--color-teal) 40%,
      transparent 70%
    );
    opacity: 0.5;
  }

  @media (prefers-reduced-motion: no-preference) {
    .flare--1 {
      animation: flare-rotate-cw 30s linear infinite;
    }

    .flare--2 {
      animation: flare-rotate-ccw 38s linear infinite;
    }

    .flare--3 {
      animation: flare-rotate-cw 45s linear infinite;
    }

    .flare--4 {
      animation: flare-rotate-ccw 22s linear infinite;
    }

    .flare--5 {
      animation: flare-rotate-cw 35s linear infinite;
    }
  }
</style>
