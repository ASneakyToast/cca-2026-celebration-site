---
import type { CollectionEntry } from "astro:content";
import { formatDate, formatDateRange } from "../../lib/utils/format";

interface Props {
  event: CollectionEntry<"events">;
}

const { event } = Astro.props;
const { title, date, endDate, time, location } = event.data;
const dateDisplay = endDate ? formatDateRange(date, endDate) : formatDate(date);
---

<section class="event-hero reveal">
  <div class="container">
    <h1 class="hero-title stagger-1">{title}</h1>
    <div class="hero-meta stagger-2">
      <time class="hero-date">{dateDisplay}</time>
      <span class="hero-separator" aria-hidden="true">&#9670;</span>
      <span class="hero-time">{time}</span>
      <span class="hero-separator" aria-hidden="true">&#9670;</span>
      <span class="hero-location">{location}</span>
    </div>
  </div>
</section>

<style>
  .event-hero {
    padding-block: var(--space-12) var(--space-8);
    position: relative;
    overflow: hidden;
  }

  /* Radial gradient spotlight */
  .event-hero::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: radial-gradient(ellipse at 50% 0%, rgba(0, 191, 179, 0.06), transparent 70%);
    pointer-events: none;
  }

  .event-hero .container {
    position: relative;
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: var(--text-4xl);
    margin-bottom: var(--space-4);
    position: relative;
    display: inline-block;
    background: var(--theme-gradient);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .hero-title::after {
    content: "";
    display: block;
    width: 60px;
    height: 3px;
    background: var(--theme-gradient);
    margin-top: var(--space-3);
  }

  .hero-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-3);
    font-family: var(--font-mono);
    font-size: var(--text-lg);
    color: var(--color-muted);
    margin-top: var(--space-4);
  }

  .hero-date {
    color: var(--color-accent);
  }

  .hero-separator {
    color: var(--color-accent);
    opacity: 0.5;
    font-size: 0.6em;
  }
</style>
