---
import type { CollectionEntry } from "astro:content";

interface Props {
  event: CollectionEntry<"events">;
}

const { event } = Astro.props;
const { location, address, description, longDescription, rsvpUrl, livestreamUrl } = event.data;
---

<section class="event-details">
  <div class="details-card">
    <div class="details-location">
      <h2>Location</h2>
      <p class="location-name">{location}</p>
      <p class="location-address">{address}</p>
    </div>

    <div class="details-description">
      <h2>About</h2>
      <p>{longDescription ?? description}</p>
    </div>

    {(rsvpUrl || livestreamUrl) && (
      <div class="details-actions">
        {rsvpUrl && (
          <a href={rsvpUrl} class="action-link" target="_blank" rel="noopener noreferrer">
            RSVP
          </a>
        )}
        {livestreamUrl && (
          <a href={livestreamUrl} class="action-link" target="_blank" rel="noopener noreferrer">
            Watch Livestream
          </a>
        )}
      </div>
    )}
  </div>
</section>

<style>
  .event-details {
    padding-block: var(--space-8);
  }

  .details-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    padding: var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  h2 {
    font-size: var(--text-lg);
    margin-bottom: var(--space-2);
  }

  .location-name {
    font-weight: 600;
  }

  .location-address {
    font-size: var(--text-sm);
    color: var(--color-muted);
  }

  .details-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    padding-top: var(--space-2);
  }

  .action-link {
    display: inline-block;
    padding: var(--space-3) var(--space-6);
    background: var(--color-accent);
    color: var(--color-bg);
    text-decoration: none;
    font-size: var(--text-sm);
    font-weight: 600;
    transition: opacity 0.2s ease;
  }

  .action-link:hover {
    opacity: 0.85;
  }
</style>
